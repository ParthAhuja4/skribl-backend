{
  "name": "syncdrawguess-server",
  "version": "1.0.1",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "ts-node-dev --clear ./src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "start:cluster": "node dist/src/cluster.js",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "backup": "bash backup.sh",
    "restore": "bash restore.sh"
  },
  "author": "",
  "license": "ISC",
  "description": "Production-grade multiplayer drawing and guessing game server with voice chat support",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/node-forge": "^1.3.14",
    "bad-words": "^4.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "node-forge": "^1.3.3",
    "readline": "^1.3.0",
    "redis": "^4.7.0",
    "socket.io": "^4.7.5",
    "validator": "^13.15.26",
    "winston": "^3.19.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.1.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  }
}
